# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Supabase Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anonymous Key (safe to use in browser)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (keep secret, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Supabase Database URL for direct connections
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=businessdatagurus@gmail.com
SMTP_PASSWORD=your-app-password

# Crypto Wallet Addresses
BTC_WALLET_ADDRESS=your-btc-wallet-address
ETH_WALLET_ADDRESS=your-eth-wallet-address

# Analytics
GOOGLE_ANALYTICS_ID=UA-494117515-1
MICROSOFT_CLARITY_ID=s2rctzchym

# Environment
NODE_ENV=development
