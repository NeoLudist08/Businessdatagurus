<script>
  const BDG_URL = 'https://bdywkygsvriaibjddcey.supabase.co';
  const BDG_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJkeXdreWdzdnJpYWliamRkY2V5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY3Mzg1MTgsImV4cCI6MjA5MjMxNDUxOH0.Xs8Ohj4yq2bw-sInys8jx8KusfepPWjvxBVYxFpYjCM';
  const SOURCE = 'humanit-landing';

  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('shown');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach((el, i) => {
    if (!el.style.getPropertyValue('--i')) el.style.setProperty('--i', i % 6);
    observer.observe(el);
  });

  async function submitWaitlist(form, statusEl) {
    const email = form.querySelector('input[type="email"]').value.trim();
    if (!email) return;
    statusEl.textContent = 'Submitting…';
    statusEl.className = 'mt-3 text-sm px-4 py-2 rounded-lg form-success max-w-md' + (statusEl.id === 'cta-status' ? ' mx-auto' : '');
    statusEl.classList.remove('hidden');
    try {
      const res = await fetch(`${BDG_URL}/rest/v1/bdg_intakes`, {
        method: 'POST',
        headers: {
          'apikey': BDG_ANON_KEY,
          'Authorization': `Bearer ${BDG_ANON_KEY}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal'
        },
        body: JSON.stringify({
          email: email,
          service_interest: 'Humanit',
          source: SOURCE,
          status: 'waitlist',
          message: `Waitlist signup from ${SOURCE}`
        })
      });
      if (res.ok || res.status === 201) {
        form.reset();
        statusEl.textContent = "✓ You're on the Humanit waitlist. Early access opens soon.";
      } else {
        throw new Error(`HTTP ${res.status}`);
      }
    } catch (err) {
      statusEl.textContent = 'Something went wrong. Email hello@businessdatagurus.com instead.';
      statusEl.className = 'mt-3 text-sm px-4 py-2 rounded-lg form-error max-w-md' + (statusEl.id === 'cta-status' ? ' mx-auto' : '');
      console.error(err);
    }
  }

  document.getElementById('waitlist-hero').addEventListener('submit', (e) => {
    e.preventDefault();
    submitWaitlist(e.target, document.getElementById('hero-status'));
  });
  document.getElementById('waitlist-cta').addEventListener('submit', (e) => {
    e.preventDefault();
    submitWaitlist(e.target, document.getElementById('cta-status'));
  });
</script>

