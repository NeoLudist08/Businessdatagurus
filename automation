});

/* CONTACT FORM */
document.getElementById('contact-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const status = document.getElementById('form-status');
    const tier = document.getElementById('i-tier').value;
    const data = {
        email: document.getElementById('i-email').value,
        name: document.getElementById('i-name').value || null,
        company: null,
        service_interest: 'Private Cloud',
        source: CONFIG.SOURCE,
        status: 'discovery',
        message: `Tier: ${tier} | ${document.getElementById('i-message').value || '(no details)'}`
    };
    status.textContent = 'Sending…'; status.className = 'form-status ok';
    try {
        const res = await fetch(`${CONFIG.SUPABASE_URL}/rest/v1/bdg_intakes`, {
            method: 'POST',
            headers: {
                'apikey': CONFIG.SUPABASE_ANON_KEY,
                'Authorization': `Bearer ${CONFIG.SUPABASE_ANON_KEY}`,
                'Content-Type': 'application/json',
                'Prefer': 'return=minimal'
            },
            body: JSON.stringify(data)
        });
        if (res.ok || res.status === 201) {
            e.target.reset();
            status.textContent = "✓ Got it. We'll be in touch within one business day."; status.className = 'form-status ok';
        } else { throw new Error('HTTP ' + res.status); }
    } catch (err) {
        status.textContent = 'Send failed. Email businessdatagurus@gmail.com instead.'; status.className = 'form-status err';
    }
});
</script>

